# Honcho self-hosted environment
# Copy to ~/honcho/.env and fill in your keys.
# Any OpenAI-compatible provider works (OpenRouter, Venice, Routstr, Together, etc.)

# Primary LLM provider (via "vllm" slot)
LLM_VLLM_API_KEY=your-primary-api-key
LLM_VLLM_BASE_URL=https://openrouter.ai/api/v1

# Backup LLM provider (via "custom" slot) + embeddings
# Leave empty to disable backup
LLM_OPENAI_COMPATIBLE_API_KEY=your-backup-api-key

# Same as primary key (needed for client initialization)
LLM_OPENAI_API_KEY=your-primary-api-key
