# Honcho self-hosted environment
# Copy this to ~/honcho/.env and fill in your keys.

# OpenRouter — primary LLM provider (via "vllm" slot)
LLM_VLLM_API_KEY=your-openrouter-key
LLM_VLLM_BASE_URL=https://openrouter.ai/api/v1

# Venice — backup LLM provider (via "custom" slot) + embeddings
# NOTE: embeddings also route through Venice because Honcho's "openrouter"
# embedding client shares OPENAI_COMPATIBLE_* with the "custom" LLM client.
LLM_OPENAI_COMPATIBLE_API_KEY=your-venice-api-key

# Needed for OpenAI client initialization
LLM_OPENAI_API_KEY=your-openrouter-key
